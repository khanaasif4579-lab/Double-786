# Application
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/asif-ali-studio

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# API Encryption
API_ENCRYPTION_KEY=your-32-character-encryption-key

# AWS S3 (File Storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=asif-ali-studio-bucket

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_EMAIL=noreply@asifalistudio.com

# AI APIs
OPENAI_API_KEY=your-openai-key
SOUNDRAW_API_KEY=your-soundraw-key
ELEVENLABS_API_KEY=your-elevenlabs-key
DALLE_API_KEY=your-dalle-key

# Logger
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Session
SESSION_SECRET=your-session-secret
SESSION_TIMEOUT=1800000

# 2FA
TWO_FACTOR_WINDOW=30
TWO_FACTOR_BACKUP_CODES=10

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900000

# File Upload
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=pdf,mp3,wav,jpg,png

# Admin Settings
ADMIN_EMAIL=admin@asifalistudio.com
LICENSE_PRICE=15000
LICENSE_CURRENCY=INR
